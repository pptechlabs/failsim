{
  "name": "failsim",
  "version": "0.1.0",
  "description": "API Failure Simulator for developers",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./express": {
      "types": "./dist/adapters/express.d.ts",
      "import": "./dist/adapters/express.mjs",
      "require": "./dist/adapters/express.js"
    },
    "./axios": {
      "types": "./dist/adapters/axios.d.ts",
      "import": "./dist/adapters/axios.mjs",
      "require": "./dist/adapters/axios.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "testing",
    "api",
    "failure",
    "simulator",
    "mock",
    "http",
    "fetch",
    "axios",
    "express",
    "chaos",
    "reliability"
  ],
  "author": "PP Techlabs pp.techlabs@gmail.com",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pptechlabs/failsim.git"
  },
  "bugs": {
    "url": "https://github.com/pptechlabs/failsim/issues"
  },
  "homepage": "https://github.com/pptechlabs/failsim#readme",
  "peerDependencies": {
    "axios": ">=1.0.0",
    "express": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "axios": {
      "optional": true
    },
    "express": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "axios": "^1.6.5",
    "express": "^4.18.2",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  }
}